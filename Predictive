        "1 import numpy as np\n",
        "2 import matplotlib.pyplot as plt\n",
        " from sklearn.linear_model import LinearRegression\n",
        "from sklearn.preprocessing import PolynomialFeatures\n",
        "from sklearn.metrics import r2_score\n",
        "# Data\n",
        "x = np.array([1,2,3,5,6,7,8,9,10,12,13,14,15,16,18,19,21,22]).reshape(-1,1)\n",
        "y = np.array([100,90,80,60,60,55,60,65,70,70,75,76,78,79,90,99,99,100])\n",
        "# 1. Linear Regression Model\n",
        "linear_model = LinearRegression()\n",
        "linear_model.fit(x, y)\n",
        "y_pred_linear = linear_model.predict(x)\n",
        "# 2. Polynomial Regression (degree 2)\n",
        "poly = PolynomialFeatures(degree=2)\n",
        "x_poly = poly.fit_transform(x)\n",
        "poly_model = LinearRegression()\n",
        "poly_model.fit(x_poly, y)\n",
        "y_pred_poly = poly_model.predict(x_poly)\n",
        "# Evaluation\n",
        "r2_linear = r2_score(y, y_pred_linear)\n",
        "r2_poly = r2_score(y, y_pred_poly)\n",
        "print(\"Linear Regression R^2:\", r2_linear)\n",
        "print(\"Polynomial Regression R^2:\", r2_poly)\n",
        "# Visualization\n",
        "plt.scatter(x, y, color='black', label='Actual data')\n",
        "plt.plot(x, y_pred_linear, label='Linear fit', linestyle='--')\n",
        "plt.plot(x, y_pred_poly, label='Quadratic fit', linewidth=2)\n",
        "plt.title(\"Regression Analysis of TV Ads vs Sales\")\n",
        "plt.xlabel(\"TV Commercials (x)\")\n",
        "plt.ylabel(\"Sales (y)\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
